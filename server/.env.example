# ── Copy this file to .env and fill in your values ──────────
# NEVER commit .env to git

# Supabase (get from supabase.com → project → settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Admin passcode for theme management
ADMIN_PASSCODE=your-secret-admin-password

# Your local AI model URL
# During dev: http://localhost:11434
# In prod: your ngrok URL OR a machine with a public IP running ollama
AI_BASE_URL=http://localhost:11434

# Port (Railway sets this automatically)
PORT=3001
